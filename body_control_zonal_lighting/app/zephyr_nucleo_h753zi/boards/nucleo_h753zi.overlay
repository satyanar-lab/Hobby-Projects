/*
 * GPIO devicetree overlay for the body-control zonal lighting demo.
 *
 * Maps the five lamp output functions to GPIO pins for the Zephyr build.
 * PB0 is reserved by the board DTS as green_led (User LD1) and must not be
 * claimed here.  Left Indicator is routed to PB5 which is uncontested.
 *
 * Each node label is resolved at compile time by ZephyrGpioDriver via
 * GPIO_DT_SPEC_GET(DT_NODELABEL(<label>), gpios).
 *
 * Wiring: connect LED anode to the listed NUCLEO Morpho pin, cathode to
 * any GND pin, with a 330 Ω resistor in series.
 *   PB5 → Left Indicator  (CN10 pin 29)
 *   PB1 → Right Indicator (CN10 pin 24)
 *   PB2 → Hazard Lamp     (CN10 pin 22)
 *   PB3 → Park Lamp       (CN10 pin 26)
 *   PB4 → Head Lamp       (CN10 pin 27)
 */

/ {
    lamp_outputs {
        compatible = "gpio-leds";

        left_indicator: left_indicator {
            gpios = <&gpiob 5 GPIO_ACTIVE_HIGH>;
            label = "LEFT_INDICATOR";
        };

        right_indicator: right_indicator {
            gpios = <&gpiob 1 GPIO_ACTIVE_HIGH>;
            label = "RIGHT_INDICATOR";
        };

        hazard_lamp: hazard_lamp {
            gpios = <&gpiob 2 GPIO_ACTIVE_HIGH>;
            label = "HAZARD_LAMP";
        };

        park_lamp: park_lamp {
            gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>;
            label = "PARK_LAMP";
        };

        head_lamp: head_lamp {
            gpios = <&gpiob 4 GPIO_ACTIVE_HIGH>;
            label = "HEAD_LAMP";
        };
    };
};

/*
 * Disable SPI1 to free PB5 for left_indicator GPIO use.
 *
 * The board DTS enables &spi1 with pinctrl-0 = <&spi1_mosi_pb5>, which
 * configures PB5 in alternate function mode (AF5) before main() runs.
 * Without this override, the GPIO write to PB5 has no observable effect
 * because the pin is owned by the SPI1 peripheral, not GPIOB.
 */
&spi1 {
    status = "disabled";
};
